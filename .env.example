# AWS Credentials (auto-populated by configure-env.sh)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ca-central-1

# Route53 Configuration (auto-populated by configure-env.sh)
HOSTED_ZONE_ID=
# Comma-separated list of DNS records (e.g., home.example.com,*.example.com)
DNS_RECORD_NAMES=

# DNS TTL (in seconds)
DNS_TTL=300
