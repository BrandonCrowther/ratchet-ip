# AWS Credentials (auto-populated by configure-env.sh)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ca-central-1

# Route53 Configuration (HOSTED_ZONE_ID auto-populated by configure-env.sh)
HOSTED_ZONE_ID=
# Set this to match dns_record_name in terraform.tfvars
DNS_RECORD_NAME=

# DNS TTL (in seconds)
DNS_TTL=300
